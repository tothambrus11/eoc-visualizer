{
  "name": "eoc",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build:grammar": "nearleyc src/grammar/concurrency.ne -o src/grammar/concurrency.js && node scripts/esmify-grammar.mjs",
    "predev": "npm run build:grammar",
    "prebuild": "npm run build:grammar",
    "pretest": "npm run build:grammar",
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "elkjs": "^0.11.1",
    "mermaid": "^11.15.0",
    "nearley": "^2.20.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-x-mermaid": "^0.0.10"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/nearley": "^2.11.5",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^3.2.6"
  }
}
